# Frontend configuration
# Copy this to .env and fill in your values

# Full URL to your backend (HF Spaces URL after deployment)
# Leave empty when running locally (same-origin via npm run dev)
VITE_BACKEND_URL="https://your-username-dipchat-backend.hf.space"

# Must match BACKEND_API_KEY in the root .env / HF Spaces secrets
VITE_BACKEND_API_KEY="your-secret-api-key-here"
